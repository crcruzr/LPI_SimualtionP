# Load required library
library(ggplot2)
# Define data
years <- seq(1970, 2015, by=5)
world_trend <- c(100, 90, 80, 75, 65, 60, 55, 50, 45, 40)
europe_trend <- c(100, 95, 100, 110, 105, 100, 95, 90, 85, 80)
asia_africa_trend <- c(100, 85, 70, 65, 60, 55, 50, 45, 40, 35)
latin_trend <- c(100, 80, 60, 50, 45, 40, 35, 30, 25, 20)
# Combine into dataframe
df <- data.frame(
years = rep(years, 4),
trend = c(world_trend, europe_trend, asia_africa_trend, latin_trend),
group = rep(c("World", "Europe", "AsiaAfrica", "Latin"), each=length(years))
)
# Define confidence interval factors
ci_factors <- c(0.05, 0.2, 0.1, 0.05)
df$ci <- rep(ci_factors, each=length(years))
# Calculate upper and lower CIs
df$upper <- df$trend * (1 + df$ci)
df$lower <- df$trend * (1 - df$ci)
line_colors <- c("#7b3294", "#008837", "#a6dba0", "#c2a5cf")
fill_colors <- c("#c2a5cf66", "#a6dba066", "#f4a58266", "#92c5de66")
# Plot
ggplot(df, aes(x=years, y=trend, color=group, fill=group)) +
geom_line(size=1) +
geom_ribbon(aes(ymin=lower, ymax=upper), alpha=0.3, color=NA) +
scale_color_manual(values=line_colors) +
scale_fill_manual(values=fill_colors) +
geom_hline(yintercept = 100, linetype = "dashed", color = "black", size = 0.5)+
theme_minimal() +
theme(
axis.title=element_blank(),
axis.text=element_blank(),
panel.grid=element_blank()
) +
geom_hline(yintercept=0, color="black", size=0.3) +
geom_vline(xintercept=1970, color="black", size=0.3)
# Plot
p <-ggplot(df, aes(x=years, y=trend, color=group, fill=group)) +
geom_line(size=1) +
geom_ribbon(aes(ymin=lower, ymax=upper), alpha=0.3, color=NA) +
scale_color_manual(values=line_colors) +
scale_fill_manual(values=fill_colors) +
geom_hline(yintercept = 100, linetype = "dashed", color = "black", size = 0.5)+
theme_minimal() +
theme(
axis.title=element_blank(),
axis.text=element_blank(),
panel.grid=element_blank()
) +
geom_hline(yintercept=0, color="black", size=0.3) +
geom_vline(xintercept=1970, color="black", size=0.3)
ggsave("trend_plotPPpt.png", plot = p, width = 10, height = 6, dpi = 300)
ggsave("04Plots/trend_plotPPpt.png", plot = p, width = 10, height = 6, dpi = 300)
line_colors <- c("#9467bd", "#a285c0", "#8a68b3", "#9b7fc8")
fill_colors <- c("#c5b0d5", "#d2c3dd", "#bfa6d3", "#ccb8da")
line_colors <- c("#9467bd", "#a285c0", "#8a68b3", "#9b7fc8")
fill_colors <- c("#c5b0d5", "#d2c3dd", "#bfa6d3", "#ccb8da")
# Plot
p <-ggplot(df, aes(x=years, y=trend, color=group, fill=group)) +
geom_line(size=1) +
geom_ribbon(aes(ymin=lower, ymax=upper), alpha=0.3, color=NA) +
scale_color_manual(values=line_colors) +
scale_fill_manual(values=fill_colors) +
geom_hline(yintercept = 100, linetype = "dashed", color = "black", size = 0.5)+
theme_minimal() +
theme(
axis.title=element_blank(),
axis.text=element_blank(),
panel.grid=element_blank()
) +
geom_hline(yintercept=0, color="black", size=0.3) +
geom_vline(xintercept=1970, color="black", size=0.3)
p
ggsave("04Plots/trend_plotPPpt2.png", plot = p, width = 10, height = 6, dpi = 300)
